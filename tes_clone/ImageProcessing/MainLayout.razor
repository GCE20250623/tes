<main>
    @Body
</main>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #1a1a2e; color: #eee; }
    main { max-width: 1400px; margin: 0 auto; padding: 20px; }
    .card { background: #16213e; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
    h1, h2, h3 { color: #00d4ff; }
    .btn { background: #00d4ff; color: #1a1a2e; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer; }
    .btn:hover { background: #00b8d4; }
    input[type="file"] { background: #0f3460; color: #fff; padding: 8px; border-radius: 4px; }
    textarea { background: #0f3460; color: #fff; border: 1px solid #333; padding: 12px; border-radius: 4px; width: 100%; min-height: 150px; }
    .preview-img { max-width: 400px; border: 2px solid #00d4ff; margin: 10px 0; }
</style>
