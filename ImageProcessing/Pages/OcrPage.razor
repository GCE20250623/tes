@**
 * 文字识别（OCR）页面
 * 
 * 功能说明：
 * - 上传单张或多张图片进行文字识别
 * - 配置识别语言和预处理参数
 * - 显示识别结果和置信度
 * - 支持复制和编辑识别文字
 * - 多图片合并识别
 * 
 * 页面路由：/ocr
 *_

@page "/ocr"
@layout MainLayout
@inject OcrService Ocr

<div class="card">
    @* 页面标题 *@
    <h2>📝 文字识别 (OCR)</h2>
    <p>使用 Tesseract 进行图片文字识别，支持多张图片合并</p>
</div>

@* 上传图片区域 *@
<div class="card">
    <h3>📤 上传图片</h3>
    
    @* 文件选择输入（支持多选） *@
    <InputFile multiple OnChange="HandleFilesSelected" accept="image/*" />
    
    @* 如果已选择图片 *@
    @if (selectedImages.Any())
    {
        @* 已选择图片数量 *@
        <p>已选择 @selectedImages.Count 张图片</p>
        
        @* 图片预览网格 *@
        <div class="preview-section">
            <h4>已选择的图片</h4>
            <div class="preview-grid">
                @for (int i = 0; i < selectedImages.Count; i++)
                {
                    var index = i;
                    <div class="preview-item">
                        <img src="data:image/png;base64,@selectedImages[index].Base64" alt="Preview @(i+1)" />
                        @* 删除按钮 *@
                        <button class="btn-remove" @onclick="() => RemoveImage(index)">×</button>
                        <span class="preview-label">图片 @(i + 1)</span>
                    </div>
                }
            </div>
        </div>

        @* 识别设置区域 *@
        <div class="settings-section">
            <h3>⚙️ 识别设置</h3>
            
            <div class="settings-grid">
                @* 语言选择 - OCR需要语言训练数据 *@
                <div class="setting-item full-width">
                    <label>识别语言</label>
                    <select @bind="Settings.Language">
                        @* 英语 - 基础语言包 *@
                        <option value="eng">English</option>
                        @* 简体中文 - 需要下载chi_sim.traineddata *@
                        <option value="chi_sim">简体中文</option>
                        @* 中英混合 - 同时识别中英文 *@
                        <option value="eng+chi_sim">English + 简体中文</option>
                        @* 日语 - 需要下载jpn.traineddata *@
                        <option value="jpn">日本語</option>
                        @* 韩语 - 需要下载kor.traineddata *@
                        <option value="kor">한국어</option>
                    </select>
                    <span class="hint">需要对应的tessdata语言文件</span>
                </div>
                
                @* 对比度增强开关 *@
                <div class="setting-item">
                    <label>对比度增强</label>
                    <input type="checkbox" @bind="Settings.EnhanceContrast" />
                    <span class="hint">自动提高文字对比度</span>
                </div>
                
                @* 去噪处理开关 *@
                <div class="setting-item">
                    <label>去噪处理</label>
                    <input type="checkbox" @bind="Settings.RemoveNoise" />
                    <span class="hint">去除图片噪点</span>
                </div>
                
                @* 自适应阈值块大小 *@
                <div class="setting-item">
                    <label>阈值块大小</label>
                    <input type="number" @bind="Settings.ThresholdBlockSize" min="3" max="51" step="2" />
                    <span class="hint">必须是奇数 (3,5,7...)</span>
                </div>
                
                @* 阈值C值 *@
                <div class="setting-item">
                    <label>阈值C值</label>
                    <input type="number" @bind="Settings.ThresholdC" min="1" max="20" />
                    <span class="hint">影响二值化效果</span>
                </div>
            </div>

            @* 操作按钮组 *@
            <div class="button-group">
                @* 识别第一张图片 *@
                <button class="btn btn-primary" @onclick="RecognizeText" disabled="@(selectedImages.Count == 0)">
                    🔍 识别首张图片
                </button>
                
                @* 合并所有图片识别（仅在有多张图片时显示） *@
                @if (selectedImages.Count > 1)
                {
                    <button class="btn btn-secondary" @onclick="CombineAndRecognize">
                        📑 合并所有图片识别
                    </button>
                }
                
                @* 清空所有已选图片 *@
                <button class="btn btn-outline" @onclick="ClearAll">
                    🗑️ 清空
                </button>
            </div>
        </div>
    }
</div>

@* 加载中状态 *@
@if (isProcessing)
{
    <div class="card processing">
        <div class="spinner"></div>
        <p>正在识别文字...</p>
    </div>
}

@* 识别错误提示 *@
@if (result != null && !result.IsSuccess && !string.IsNullOrEmpty(result.Error))
{
    <div class="card error">
        <h3>❌ 识别失败</h3>
        <p>@result.Error</p>
        
        @* 如果是tessdata缺失错误，给出提示 *@
        @if (result.Error.Contains("tessdata"))
        {
            <p class="hint">
                提示: 请确保已下载对应语言的训练数据到 tessdata 目录
                <br/>
                语言包下载: https://github.com/tesseract-ocr/tessdata
            </p>
        }
    </div>
}

@* 识别结果展示 *@
@if (result != null && result.IsSuccess)
{
    <div class="card results">
        <h3>📊 识别结果</h3>
        
        @* 统计信息卡片 *@
        <div class="stats-row">
            @* 识别置信度 *@
            <div class="stat-card primary">
                <span class="stat-value">@result.Confidence%</span>
                <span class="stat-label">置信度</span>
            </div>
            @* 识别到的文本块数量 *@
            <div class="stat-card">
                <span class="stat-value">@result.Blocks.Count</span>
                <span class="stat-label">文本块</span>
            </div>
            @* 识别的字符总数 *@
            <div class="stat-card">
                <span class="stat-value">@result.Text.Length</span>
                <span class="stat-label">字符数</span>
            </div>
        </div>

        @* 图片信息 *@
        @if (!string.IsNullOrEmpty(result.ImageInfo))
        {
            <p class="image-info">ℹ️ @result.ImageInfo</p>
        }

        @* 文字输出区域 *@
        <div class="text-output-section">
            <div class="text-header">
                <h4>📄 识别文字</h4>
                <div class="button-group">
                    @* 复制按钮 *@
                    <button class="btn btn-small" @onclick="CopyText">📋 复制</button>
                    @* 全选按钮 *@
                    <button class="btn btn-small btn-outline" @onclick="SelectAll">全选</button>
                </div>
            </div>
            
            @* 可编辑的文本区域 *@
            <textarea @bind="result.Text" class="result-textarea" rows="12"></textarea>
            
            @* 复制成功提示 *@
            @if (copySuccess)
            {
                <span class="copy-success">✅ 已复制到剪贴板</span>
            }
        </div>

        @* 文本块详情列表 *@
        @if (result.Blocks.Any())
        {
            <h4>📋 文本块详情</h4>
            <div class="blocks-list">
                @foreach (var block in result.Blocks)
                {
                    <div class="block-item">
                        <div class="block-header">
                            <span class="block-index">块 #@(block.Index + 1)</span>
                            <span class="block-confidence">置信度: @block.Confidence%</span>
                            <span class="block-position">位置: (@block.X, @block.Y) @block.Width×@block.Height</span>
                        </div>
                        <div class="block-text">@block.Text</div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    // ==================== 组件状态 ====================
    
    /// <summary>已选择的图片列表</summary>
    private List<ImageItem> selectedImages = new();
    
    /// <summary>OCR识别结果</summary>
    private OcrService.OcrResult? result;
    
    /// <summary>是否正在处理</summary>
    private bool isProcessing;
    
    /// <summary>复制成功标志</summary>
    private bool copySuccess;
    
    /// <summary>全选状态</summary>
    private bool isSelectingAll;
    
    /// <summary>OCR识别配置</summary>
    private OcrService.OcrSettings Settings { get; set; } = new();

    /// <summary>图片项内部类</summary>
    private class ImageItem
    {
        /// <summary>图片原始数据</summary>
        public byte[] Data { get; set; } = Array.Empty<byte>();
        
        /// <summary>Base64编码（用于显示）</summary>
        public string Base64 { get; set; } = "";
    }

    // ==================== 生命周期方法 ====================

    /// <summary>
    /// 组件初始化时设置默认参数
    /// </summary>
    protected override void OnInitialized()
    {
        Settings = new OcrService.OcrSettings
        {
            Language = "eng+chi_sim",  // 默认中英混合
            EnhanceContrast = true,
            RemoveNoise = true,
            ThresholdBlockSize = 11,
            ThresholdC = 2
        };
    }

    // ==================== 事件处理 ====================

    /// <summary>
    /// 处理文件选择事件
    /// 支持多选图片
    /// </summary>
    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles();
        
        foreach (var file in files)
        {
            // 限制单个文件大小
            if (file.Size > 10 * 1024 * 1024)
            {
                continue; // 跳过过大的文件
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            
            var data = memoryStream.ToArray();
            
            selectedImages.Add(new ImageItem
            {
                Data = data,
                Base64 = Convert.ToBase64String(data)
            });
        }
        
        result = null; // 清空之前的结果
    }

    /// <summary>
    /// 移除指定索引的图片
    /// </summary>
    private void RemoveImage(int index)
    {
        if (index >= 0 && index < selectedImages.Count)
        {
            selectedImages.RemoveAt(index);
        }
    }

    /// <summary>
    /// 清空所有已选图片
    /// </summary>
    private void ClearAll()
    {
        selectedImages.Clear();
        result = null;
        copySuccess = false;
    }

    /// <summary>
    /// 识别第一张图片的文字
    /// </summary>
    private void RecognizeText()
    {
        if (!selectedImages.Any()) return;

        isProcessing = true;
        copySuccess = false;

        try
        {
            result = Ocr.RecognizeText(selectedImages.First().Data, Settings);
        }
        catch (Exception ex)
        {
            // 处理错误
            Console.Error.WriteLine($"OCR识别错误: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    /// <summary>
    /// 合并并识别所有已选图片
    /// 适用于多页文档
    /// </summary>
    private void CombineAndRecognize()
    {
        if (!selectedImages.Any()) return;

        isProcessing = true;
        copySuccess = false;

        try
        {
            // 提取所有图片数据
            var allData = selectedImages.Select(img => img.Data).ToList();
            
            // 调用多图识别
            result = Ocr.RecognizeMultipleImages(allData, Settings);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"多图识别错误: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    /// <summary>
    /// 复制识别文字到剪贴板
    /// </summary>
    private void CopyText()
    {
        if (result != null && !string.IsNullOrEmpty(result.Text))
        {
            // 在实际应用中需要使用JS互操作复制到剪贴板
            // 这里简单显示成功提示
            copySuccess = true;
            
            // 3秒后自动隐藏提示
            Task.Delay(3000).ContinueWith(_ => copySuccess = false);
        }
    }

    /// <summary>
    /// 选中文本框中的所有文字
    /// </summary>
    private void SelectAll()
    {
        isSelectingAll = true;
        Task.Delay(100).ContinueWith(_ => isSelectingAll = false);
    }
}
